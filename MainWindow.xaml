<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Лабораторная работа №9: WPF" Height="450" Width="600">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Margin="5">
                <Label Content="Треугольник 1" FontWeight="Bold"/>
                <Label Content="Катет X:"/>
                <TextBox x:Name="txtX1" Margin="0,0,0,5"/>
                <Label Content="Катет Y:"/>
                <TextBox x:Name="txtY1" Margin="0,0,0,5"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="5">
                <Label Content="Треугольник 2" FontWeight="Bold"/>
                <Label Content="Катет X:"/>
                <TextBox x:Name="txtX2" Margin="0,0,0,5"/>
                <Label Content="Катет Y:"/>
                <TextBox x:Name="txtY2" Margin="0,0,0,5"/>
            </StackPanel>

            <UniformGrid Grid.Row="1" Grid.ColumnSpan="2" Columns="2" Margin="5">
                <Button Content="Рассчитать площадь (T1)" Click="BtnSquare_Click" Margin="2"/>
                <Button Content="ToString() (Оба)" Click="BtnToString_Click" Margin="2"/>
                <Button Content="Инкремент ++ (T1)" Click="BtnInc_Click" Margin="2"/>
                <Button Content="Декремент -- (T1)" Click="BtnDec_Click" Margin="2"/>
                <Button Content="Сравнить (&lt;= и >=)" Click="BtnCompare_Click" Margin="2"/>
                <Button Content="Приведение типов (double/bool)" Click="BtnCast_Click" Margin="2"/>
            </UniformGrid>
    
            <TextBox x:Name="txtLog" Grid.Row="2" Grid.ColumnSpan="2" Height="120" 
                     VerticalScrollBarVisibility="Auto" IsReadOnly="True" Background="#F0F0F0" Margin="5"/>
        </Grid>
</Window>